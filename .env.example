# PMM-1 Environment Variables
# Copy to .env and fill in your values

# ── Wallet ──
PMM1_WALLET_PRIVATE_KEY=0x...your_private_key...
PMM1_WALLET_ADDRESS=0x...your_wallet_address...

# ── CLOB API Credentials ──
# Generate at: https://polymarket.com/settings/api
PMM1_API_KEY=your_api_key
PMM1_API_SECRET=your_api_secret
PMM1_API_PASSPHRASE=your_api_passphrase
PMM1_API_FUNDER=0x...funder_address_if_different...

# ── Storage (optional — defaults work for local dev) ──
# PMM1_REDIS_URL=redis://localhost:6379/0
# PMM1_POSTGRES_DSN=postgresql://pmm1:pmm1@localhost:5432/pmm1

# ── Environment ──
# PMM1_BOT__ENV=prod
# PMM1_BOT__MAX_MARKETS=20
